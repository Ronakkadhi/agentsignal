PORT=3000

# Required for /ask endpoint (LLM-powered Q&A)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — enables FRED economic data source (GDP, CPI, unemployment, rates)
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional — enables Metaculus prediction market source
# Get your token at: https://www.metaculus.com/api/
METACULUS_API_TOKEN=
